{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/leifj/wmp/schema/methods/session-create-request.json",
  "title": "wmp.session.create — Request",
  "description": "Create a new WMP session.",
  "type": "object",
  "required": ["jsonrpc", "id", "method", "params"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": { "type": ["string", "integer"] },
    "method": { "const": "wmp.session.create" },
    "params": {
      "type": "object",
      "required": ["wmp"],
      "properties": {
        "wmp": { "$ref": "../wmp-metadata.json" },
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Identifiers of participants to invite."
        },
        "accepted_schemes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Accepted identifier schemes."
        },
        "capabilities_offered": { "$ref": "../wmp-capabilities.json" },
        "security": { "$ref": "../wmp-security.json" },
        "ttl": {
          "type": "integer",
          "minimum": 1,
          "description": "Session time-to-live in seconds."
        }
      }
    }
  }
}
